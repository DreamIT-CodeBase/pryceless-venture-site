generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  
}

model AdminProfile {
  id          String   @id @default(cuid())
  azureAdId   String?  @unique
  email       String   @unique
  name        String?
  avatarUrl   String?
  isActive    Boolean  @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model HomePage {
  id                    String              @id
  heroHeadline          String
  heroSubheadline       String              @db.NVarChar(Max)
  heroPrimaryCtaLabel   String
  heroPrimaryCtaHref    String
  heroSecondaryCtaLabel String?
  heroSecondaryCtaHref  String?
  aboutSectionTitle     String?
  aboutSectionParagraphOne String?          @db.NVarChar(Max)
  aboutSectionParagraphTwo String?          @db.NVarChar(Max)
  aboutSectionPrimaryCtaLabel String?
  aboutSectionPrimaryCtaHref  String?
  aboutSectionSecondaryCtaLabel String?
  aboutSectionSecondaryCtaHref  String?
  aboutSectionImageUrl  String?             @db.NVarChar(2000)
  aboutSectionImageAlt  String?             @db.NVarChar(1000)
  metricsDisclaimer     String?             @db.NVarChar(Max)
  portfolioValueDisplay String?
  portfolioCaption      String?             @db.NVarChar(Max)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  metrics               HomeMetric[]
  segments              HomeSegment[]
  platformCards         HomePlatformCard[]
  caseHighlights        HomeCaseHighlight[]
  testimonials          HomeTestimonial[]
}

model HomeMetric {
  id         String   @id @default(cuid())
  homePageId String
  metricValue String
  metricLabel String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  homePage   HomePage @relation(fields: [homePageId], references: [id], onDelete: Cascade)

  @@index([homePageId, sortOrder])
}

model HomeSegment {
  id         String   @id @default(cuid())
  homePageId String
  title      String
  body       String   @db.NVarChar(Max)
  ctaLabel   String
  ctaHref    String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  homePage   HomePage @relation(fields: [homePageId], references: [id], onDelete: Cascade)

  @@index([homePageId, sortOrder])
}

model HomePlatformCard {
  id         String   @id @default(cuid())
  homePageId String
  title      String
  body       String   @db.NVarChar(Max)
  ctaLabel   String
  ctaHref    String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  homePage   HomePage @relation(fields: [homePageId], references: [id], onDelete: Cascade)

  @@index([homePageId, sortOrder])
}

model HomeCaseHighlight {
  id         String   @id @default(cuid())
  homePageId String
  title      String
  body       String   @db.NVarChar(Max)
  ctaLabel   String
  ctaHref    String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  homePage   HomePage @relation(fields: [homePageId], references: [id], onDelete: Cascade)

  @@index([homePageId, sortOrder])
}

model HomeTestimonial {
  id         String   @id @default(cuid())
  homePageId String
  name       String
  city       String
  quote      String   @db.NVarChar(Max)
  avatarUrl  String?  @db.NVarChar(2000)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  homePage   HomePage @relation(fields: [homePageId], references: [id], onDelete: Cascade)

  @@index([homePageId, sortOrder])
}

model SingletonPage {
  id              String                  @id @default(cuid())
  key             String                  @unique
  routePath       String                  @unique
  pageTitle       String
  intro           String?                 @db.NVarChar(Max)
  disclaimer      String?                 @db.NVarChar(Max)
  ctaLabel        String?
  ctaHref         String?
  lifecycleStatus String                  @default("PUBLISHED")
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  items           SingletonPageItem[]
}

model SingletonPageItem {
  id        String        @id @default(cuid())
  pageId     String
  groupKey   String
  title      String
  body       String?      @db.NVarChar(Max)
  ctaLabel   String?
  ctaHref    String?
  sortOrder  Int          @default(0)
  createdAt  DateTime     @default(now())
  page       SingletonPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId, groupKey, sortOrder])
}

model MediaFile {
  id              String             @id @default(cuid())
  blobUrl         String
  blobPath        String             @unique
  fileName        String
  mimeType        String
  fileSize        Int?
  altText         String?            @db.NVarChar(1000)
  metadata        String?            @db.NVarChar(Max)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  propertyImages  PropertyImage[]
  investmentImages InvestmentImage[]
  caseStudyImages CaseStudyImage[]
}

model Property {
  id             String                  @id @default(cuid())
  title          String
  slug           String                  @unique
  lifecycleStatus String                 @default("DRAFT")
  status         String
  locationCity   String?
  locationState  String?
  propertyType   String
  strategy       String
  summary        String                  @db.NVarChar(Max)
  buyerFit       String?                 @db.NVarChar(Max)
  detailContent  String?                 @db.NVarChar(Max)
  inquiryFormId  String?
  primaryImageId String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  inquiryForm    FormDefinition?         @relation("PropertyInquiryForm", fields: [inquiryFormId], references: [id], onDelete: SetNull)
  primaryImage   PropertyImage?          @relation("PropertyPrimaryImage", fields: [primaryImageId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  highlights     PropertyHighlight[]
  images         PropertyImage[]         @relation("PropertyImages")

  @@index([lifecycleStatus, createdAt])
}

model PropertyHighlight {
  id         String   @id @default(cuid())
  propertyId  String
  highlight   String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, sortOrder])
}

model PropertyImage {
  id                 String    @id @default(cuid())
  propertyId         String
  mediaFileId        String
  caption            String?   @db.NVarChar(Max)
  altText            String?   @db.NVarChar(1000)
  sortOrder          Int       @default(0)
  createdAt          DateTime  @default(now())
  mediaFile          MediaFile @relation(fields: [mediaFileId], references: [id], onDelete: Cascade)
  property           Property  @relation("PropertyImages", fields: [propertyId], references: [id], onDelete: Cascade)
  primaryForProperty Property[] @relation("PropertyPrimaryImage")

  @@unique([propertyId, mediaFileId])
  @@index([propertyId, sortOrder])
}

model Investment {
  id                       String                  @id @default(cuid())
  title                    String
  slug                     String                  @unique
  lifecycleStatus          String                  @default("DRAFT")
  status                   String
  assetType                String
  strategy                 String
  summary                  String                  @db.NVarChar(Max)
  minimumInvestmentDisplay String?
  returnsDisclaimer        String?                 @db.NVarChar(Max)
  dealPacketFormId         String?
  primaryImageId           String?
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  dealPacketForm           FormDefinition?         @relation("InvestmentDealPacketForm", fields: [dealPacketFormId], references: [id], onDelete: SetNull)
  primaryImage             InvestmentImage?        @relation("InvestmentPrimaryImage", fields: [primaryImageId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  highlights               InvestmentHighlight[]
  images                   InvestmentImage[]       @relation("InvestmentImages")

  @@index([lifecycleStatus, createdAt])
}

model InvestmentHighlight {
  id           String      @id @default(cuid())
  investmentId String
  highlight    String
  sortOrder    Int         @default(0)
  createdAt    DateTime    @default(now())
  investment   Investment  @relation(fields: [investmentId], references: [id], onDelete: Cascade)

  @@index([investmentId, sortOrder])
}

model InvestmentImage {
  id                    String      @id @default(cuid())
  investmentId          String
  mediaFileId           String
  caption               String?     @db.NVarChar(Max)
  altText               String?     @db.NVarChar(1000)
  sortOrder             Int         @default(0)
  createdAt             DateTime    @default(now())
  mediaFile             MediaFile   @relation(fields: [mediaFileId], references: [id], onDelete: Cascade)
  investment            Investment  @relation("InvestmentImages", fields: [investmentId], references: [id], onDelete: Cascade)
  primaryForInvestment  Investment[] @relation("InvestmentPrimaryImage")

  @@unique([investmentId, mediaFileId])
  @@index([investmentId, sortOrder])
}

model CaseStudy {
  id              String                  @id @default(cuid())
  title           String
  slug            String                  @unique
  lifecycleStatus String                  @default("DRAFT")
  category        String
  overview        String                  @db.NVarChar(Max)
  businessPlan    String                  @db.NVarChar(Max)
  execution       String                  @db.NVarChar(Max)
  outcomeSummary  String                  @db.NVarChar(Max)
  primaryImageId  String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  primaryImage    CaseStudyImage?         @relation("CaseStudyPrimaryImage", fields: [primaryImageId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assetProfile    CaseStudyAssetProfile[]
  images          CaseStudyImage[]        @relation("CaseStudyImages")
  takeaways       CaseStudyTakeaway[]

  @@index([lifecycleStatus, createdAt])
}

model CaseStudyImage {
  id                   String      @id @default(cuid())
  caseStudyId          String
  mediaFileId          String
  caption              String?     @db.NVarChar(Max)
  altText              String?     @db.NVarChar(1000)
  sortOrder            Int         @default(0)
  createdAt            DateTime    @default(now())
  mediaFile            MediaFile   @relation(fields: [mediaFileId], references: [id], onDelete: Cascade)
  caseStudy            CaseStudy   @relation("CaseStudyImages", fields: [caseStudyId], references: [id], onDelete: Cascade)
  primaryForCaseStudy  CaseStudy[] @relation("CaseStudyPrimaryImage")

  @@unique([caseStudyId, mediaFileId])
  @@index([caseStudyId, sortOrder])
}

model CaseStudyAssetProfile {
  id          String    @id @default(cuid())
  caseStudyId String
  label       String
  value       String
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  caseStudy   CaseStudy @relation(fields: [caseStudyId], references: [id], onDelete: Cascade)

  @@index([caseStudyId, sortOrder])
}

model CaseStudyTakeaway {
  id          String    @id @default(cuid())
  caseStudyId String
  takeaway    String
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  caseStudy   CaseStudy @relation(fields: [caseStudyId], references: [id], onDelete: Cascade)

  @@index([caseStudyId, sortOrder])
}

model BlogPost {
  id               String   @id @default(cuid())
  title            String
  slug             String   @unique
  lifecycleStatus  String   @default("DRAFT")
  category         String
  excerpt          String   @db.NVarChar(Max)
  content          String   @db.NVarChar(Max)
  authorName       String?
  readTime         String?
  featuredImageUrl String?  @db.NVarChar(2000)
  featuredImageAlt String?  @db.NVarChar(1000)
  publishedAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([lifecycleStatus, publishedAt, updatedAt])
}

model Calculator {
  id              String                  @id @default(cuid())
  title           String
  slug            String                  @unique
  lifecycleStatus String                  @default("DRAFT")
  calculatorType  String
  shortDescription String?                @db.NVarChar(Max)
  disclaimer      String                  @db.NVarChar(Max)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([lifecycleStatus, createdAt])
}

model LoanProgram {
  id               String           @id @default(cuid())
  title            String
  slug             String           @unique
  lifecycleStatus  String           @default("DRAFT")
  highlightTitle   String?
  titleTail        String?
  heroBadgeOne     String?
  heroBadgeTwo     String?
  heroBadgeThree   String?
  shortDescription String           @db.NVarChar(Max)
  fullDescription  String           @db.NVarChar(Max)
  interestRate     String?
  ltv              String?
  loanTerm         String?
  fees             String?          @db.NVarChar(Max)
  minAmount        String?
  maxAmount        String?
  keyHighlights    String?          @db.NVarChar(Max)
  highlightSubheadline String?      @db.NVarChar(Max)
  insightTitle     String?
  insightBody      String?          @db.NVarChar(Max)
  crmTag           String?
  imageUrl         String?          @db.NVarChar(2000)
  imageAlt         String?          @db.NVarChar(1000)
  highlightImageUrl String?         @db.NVarChar(2000)
  highlightImageAlt String?         @db.NVarChar(1000)
  isActive         Boolean          @default(true)
  sortOrder        Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  forms            FormDefinition[] @relation("LoanProgramFormLink")
  highlights       LoanProgramHighlight[]
  overviewItems    LoanProgramOverviewItem[]

  @@index([lifecycleStatus, isActive, sortOrder, updatedAt])
}

model LoanProgramHighlight {
  id            String      @id @default(cuid())
  loanProgramId String
  highlight     String      @db.NVarChar(Max)
  sortOrder     Int         @default(0)
  createdAt     DateTime    @default(now())
  loanProgram   LoanProgram @relation(fields: [loanProgramId], references: [id], onDelete: Cascade)

  @@index([loanProgramId, sortOrder])
}

model LoanProgramOverviewItem {
  id            String      @id @default(cuid())
  loanProgramId String
  title         String
  body          String?     @db.NVarChar(Max)
  sortOrder     Int         @default(0)
  createdAt     DateTime    @default(now())
  loanProgram   LoanProgram @relation(fields: [loanProgramId], references: [id], onDelete: Cascade)

  @@index([loanProgramId, sortOrder])
}

model FormDefinition {
  id                 String              @id @default(cuid())
  slug               String              @unique
  formName           String
  destination        String
  successMessage     String              @db.NVarChar(Max)
  webhookUrl         String?             @db.NVarChar(2000)
  linkedLoanProgramId String?
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  linkedLoanProgram  LoanProgram?        @relation("LoanProgramFormLink", fields: [linkedLoanProgramId], references: [id], onDelete: SetNull)
  fields             FormField[]
  submissions        FormSubmission[]
  investmentLinks    Investment[]        @relation("InvestmentDealPacketForm")
  propertyLinks      Property[]          @relation("PropertyInquiryForm")
}

model FormField {
  id               String         @id @default(cuid())
  formDefinitionId String
  fieldKey         String
  label            String
  type             String
  required         Boolean        @default(false)
  placeholder      String?
  options          String?        @db.NVarChar(Max)
  sortOrder        Int            @default(0)
  createdAt        DateTime       @default(now())
  formDefinition   FormDefinition @relation(fields: [formDefinitionId], references: [id], onDelete: Cascade)

  @@unique([formDefinitionId, fieldKey])
  @@index([formDefinitionId, sortOrder])
}

model FormSubmission {
  id                  String                @id @default(cuid())
  formDefinitionId    String
  submitterName       String?
  submitterEmail      String?
  submitterPhone      String?
  sourcePath          String?
  submissionEmailStatus String               @default("PENDING")
  emailError          String?               @db.NVarChar(Max)
  submissionWebhookStatus String             @default("SKIPPED")
  webhookError        String?               @db.NVarChar(Max)
  submittedAt         DateTime              @default(now())
  formDefinition      FormDefinition        @relation(fields: [formDefinitionId], references: [id], onDelete: NoAction)
  values              FormSubmissionValue[]

  @@index([formDefinitionId, submittedAt])
}

model FormSubmissionValue {
  id           String          @id @default(cuid())
  submissionId String
  label        String
  value        String          @db.NVarChar(Max)
  sortOrder    Int             @default(0)
  submission   FormSubmission  @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId, sortOrder])
}
